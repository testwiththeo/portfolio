        },
        article_date_3: { en: "March 14, 2026", id: "14 Maret 2026" },
        article_cta_3: { en: "Read", id: "Baca" },

        article_category_4: { en: "Release Quality", id: "Kualitas Rilis" },
        article_readtime_4: { en: "7 min", id: "7 menit" },
        article_title_4: {
            en: "Release Confidence Is a System: How QA Turns Uncertainty Into Predictability",
            id: "Kepercayaan Saat Rilis Itu Dibangun Lewat Sistem: Cara QA Mengubah Ketidakpastian Jadi Lebih Terprediksi",
        },
        article_desc_4: {
            en: "Shipping safely is not luck. It is the result of a clear release contract, risk-based testing, and fast feedback loops owned by the whole team.",
            id: "Rilis yang aman bukan soal hoki. Itu hasil dari release contract yang jelas, testing berbasis risiko, dan feedback loop cepat yang dijaga bareng seluruh tim.",
        },
        article_date_4: { en: "March 9, 2026", id: "9 Maret 2026" },
        article_cta_4: { en: "Read", id: "Baca" },

        article_category_5: {
            en: "Quality Engineering",
            id: "Quality Engineering",
        },
        article_readtime_5: { en: "6 min", id: "6 menit" },
        article_title_5: {
            en: "The Art of Intentional Breaking: Why QA Starts Before the First Line of Code",
            id: "Seni Menguji Secara Intensional: Kenapa QA Dimulai Sebelum Baris Kode Pertama",
        },
        article_desc_5: {
            en: "Shift-Left quality starts before coding: align in ceremonies, think from failure risk, and treat QA as a product partner from day one.",
            id: "Kualitas Shift-Left dimulai sebelum coding: selaraskan di setiap ceremony, berpikir dari risiko kegagalan, dan posisikan QA sebagai partner produk sejak hari pertama.",
        },
        article_date_5: { en: "March 2, 2026", id: "2 Maret 2026" },
        article_cta_5: { en: "Read", id: "Baca" },

    };

    const currentLang = localStorage.getItem("lang") === "id" ? "id" : "en";
    if (typeof window.__applyBlogLang === "function")
        window.__applyBlogLang(currentLang);
