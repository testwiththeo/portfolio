    <main class="w-full max-w-[700px] mx-auto px-6">
        <!-- Hero -->
        <section
            id="hero"
            class="relative pt-10 pb-8 md:pt-16 md:pb-12 fade-in"
        >
            <div class="w-full text-center flex flex-col items-center">
                <h1
                    class="text-[56px] md:text-[80px] font-serif font-medium leading-[0.9] tracking-[-0.04em] mb-6 text-[var(--foreground-primary)]"
                >
                    <span data-i18n-key="hero_title_prefix">hi, i'm</span>
                    <span class="hero-name-wave"
                        >{site.author.toLowerCase()}.<span class="waving-hand"
                            >👋🏼</span
                        >
                    </span>
                </h1>
                <p
                    data-i18n-key="hero_description"
                    class="text-[17px] md:text-[20px] leading-[1.6] text-[var(--foreground-secondary)] max-w-[550px] mb-8 font-serif"
                >
                    Software Quality Assurance Engineer with 1+ years of
                    experience who loves breaking things, helping teams ship
                    high quality software, and automating the boring stuff.
                </p>

                <div
                    class="currently-indicator fade-in fade-in-delay-4 flex justify-center w-full"
                >
                    <span data-i18n-key="hero_currently_label"
                        >Currently: Building test automation at</span
                    >
                    <a href="#work" data-i18n-key="hero_currently_link"
                        >scale for modern web products.</a
                    >
                    <span set:html={icons.arrow}></span>
                </div>
            </div>
        </section>

        <!-- About section removed per user request -->

        <!-- Projects -->
        <section id="work" class="pt-2 pb-16 scroll-reveal">
            <!-- Section Header -->
            <div
                class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-6 pb-8 border-b border-[var(--border-color)]"
            >
                <div class="max-w-[450px]">
                    <h2
                        data-i18n-key="work_overline"
                        class="text-[14px] md:text-[16px] font-mono font-medium tracking-[0.1em] text-[var(--foreground-muted)] uppercase mb-4"
                    >
                        selected work.
                    </h2>
                    <h3
                        data-i18n-key="work_title"
                        class="text-[34px] sm:text-[42px] md:text-[50px] font-serif font-medium tracking-[-0.03em] leading-[0.96] text-[var(--foreground-primary)]"
                    >
                        Quality, proven in practice.
                    </h3>
                </div>
                <p
                    data-i18n-key="work_description"
                    class="text-[15px] md:text-[16px] leading-[1.6] text-[var(--foreground-secondary)] max-w-[320px] font-light border-l border-[var(--border-color)] pl-6"
                >
                    Proven QA deliverables from fast-paced production
                    environments. Strategic test design, artifacts, and
                    engineering.
                </p>
            </div>

            <!-- Tier 1: Flagship Case Studies -->
            <div class="mb-10">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3 md:gap-4">
                    {
                        flagshipShowcase.map((item, index) => (
                            <a
                                href={item.href}
                                class="flagship-card project-bento-card p-6 group block"
                            >
                                <div class="flex items-center justify-between mb-3">
                                    <span
                                        class="work-type-badge"
                                        data-i18n-key={`flagship_type_${index}`}
                                    >
                                        {item.type}
                                    </span>
                                    <span
                                        class="text-[var(--foreground-muted)] group-hover:text-[var(--foreground-primary)] transition-colors duration-300"
                                        set:html={icons.arrow}
                                    />
                                </div>
                                <h4
                                    class="text-[20px] md:text-[23px] font-serif tracking-[-0.01em] text-[var(--foreground-primary)] leading-[1.2] mb-2.5"
                                    data-i18n-key={`flagship_title_${index}`}
                                >
                                    {item.title}
                                </h4>
                                <p
                                    class="text-[14px] leading-[1.65] text-[var(--foreground-secondary)] font-light mb-5"
                                    data-i18n-key={`flagship_desc_${index}`}
                                >
                                    {item.description}
                                </p>
                                <span class="work-cta">
                                    <span
                                        data-i18n-key={`flagship_cta_${index}`}
                                    >
                                        Explore full detail
                                    </span>{" "}
                                    <span set:html={icons.arrow} />
                                </span>
                            </a>
                        ))
                    }
                </div>
            </div>

            <!-- Tier 2: Supporting Artifacts -->
            <div class="border-t border-[var(--border-color)] pt-8 mb-10">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
                    {
                        supportingEvidence.map((item, index) => (
                            <a
                                href={item.href}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="project-bento-card p-5 group block"
                            >
                                <div class="flex items-center justify-between mb-3">
                                    <span
                                        class="work-type-badge"
                                        data-i18n-key={`supporting_type_${index}`}
                                    >
                                        {item.type}
                                    </span>
                                    <span
                                        class="text-[var(--foreground-muted)] group-hover:text-[var(--foreground-primary)] transition-colors duration-300"
                                        set:html={icons.arrow}
                                    />
                                </div>
                                <h5
                                    class="text-[17px] font-serif text-[var(--foreground-primary)] leading-[1.25] mb-2"
                                    data-i18n-key={`supporting_title_${index}`}
                                >
                                    {item.title}
                                </h5>
                                <p
                                    class="text-[13px] font-light leading-[1.55] text-[var(--foreground-secondary)]"
                                    data-i18n-key={`supporting_desc_${index}`}
                                >
                                    {item.description}
                                </p>
                            </a>
                        ))
                    }
                </div>
            </div>

            <!-- Tier 3: Automation Projects -->
            <div class="border-t border-[var(--border-color)] pt-8">
                <div class="space-y-4">
                    {
                        projects.map((project, index) => {
                            const primaryLink =
                                project.frontmatter.links?.[0]?.url ||
                                site.github;
                            return (
                                <a
                                    href={primaryLink}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="project-bento-card p-5 flex flex-col md:flex-row items-start md:items-center justify-between gap-5 group"
                                >
                                    <div class="flex-1">
                                        <div class="flex items-center gap-3 mb-2">
                                            <h5
                                                class="text-[19px] font-serif text-[var(--foreground-primary)]"
                                                data-i18n-key={`project_title_${index}`}
                                            >
                                                {project.frontmatter.title}
                                            </h5>
                                        </div>
                                        <p
                                            class="text-[14px] font-light leading-[1.6] text-[var(--foreground-secondary)]"
                                            data-i18n-key={`project_desc_${index}`}
                                        >
                                            <Fragment
                                                set:html={project.frontmatter.description.replace(
                                                    /\*\*(.+?)\*\*/g,
                                                    "<strong class='font-bold text-[var(--foreground-primary)]'>$1</strong>"
                                                )}
                                            />
                                        </p>
