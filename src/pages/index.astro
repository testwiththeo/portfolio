        const langMenuTrigger = document.getElementById("lang-menu-trigger");
        const langMenuPanel = document.getElementById("lang-menu-panel");
        const langTriggerCode = document.getElementById("lang-trigger-code");
        const langMenuItems = document.querySelectorAll(
            ".lang-menu-item[data-lang]"
        ) as NodeListOf<HTMLButtonElement>;

        const setLang = (lang: "en" | "id") => {
            localStorage.setItem("lang", lang);
            document.documentElement.lang = lang;
            if (langMenuTrigger instanceof HTMLElement)
                langMenuTrigger.dataset.currentLang = lang;
            if (langTriggerCode instanceof HTMLElement)
                langTriggerCode.textContent = lang.toUpperCase();

            // Swap flag icons
            document
                .querySelectorAll<HTMLElement>(".lang-flag.is-trigger")
                .forEach((el) => {
                    el.style.display =
                        el.dataset.langIcon === lang ? "flex" : "none";
                });

            // Update i18n text nodes
            document
                .querySelectorAll<HTMLElement>("[data-i18n-key]")
                .forEach((el) => {
                    const key = el.dataset.i18nKey as
                        | keyof typeof i18n
                        | undefined;
                    if (!key) return;
                    const value = i18n[key]?.[lang];
                    if (value) el.textContent = value;
                });

            // Mark active item
            langMenuItems.forEach((btn) => {
                const active = btn.dataset.lang === lang;
                btn.classList.toggle("is-active", active);
                btn.setAttribute("aria-current", active ? "true" : "false");
            });
        };

        const savedLang =
            (localStorage.getItem("lang") as "en" | "id" | null) || "en";
        setLang(savedLang);

        const closeLangMenu = () => {
            langMenuPanel instanceof HTMLElement &&
                langMenuPanel.classList.remove("open");
            langMenuTrigger instanceof HTMLElement &&
                langMenuTrigger.setAttribute("aria-expanded", "false");
        };

        langMenuTrigger?.addEventListener("click", () => {
            if (!(langMenuPanel instanceof HTMLElement)) return;
            const isOpen = langMenuPanel.classList.contains("open");
            isOpen
                ? closeLangMenu()
                : (langMenuPanel.classList.add("open"),
                  langMenuTrigger instanceof HTMLElement &&
                      langMenuTrigger.setAttribute("aria-expanded", "true"));
        });

        langMenuItems.forEach((btn) => {
            btn.addEventListener("click", () => {
                setLang((btn.dataset.lang as "en" | "id") || "en");
                closeLangMenu();
            });
        });

        document.addEventListener("click", (e) => {
            if (
                !(langMenuPanel instanceof HTMLElement) ||
                !(langMenuTrigger instanceof HTMLElement)
            )
                return;
            const t = e.target as Node;
            if (!langMenuPanel.contains(t) && !langMenuTrigger.contains(t))
                closeLangMenu();
        });

        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape") closeLangMenu();
        });

        // Email Copy Logic
        const copyBtn = document.getElementById("copy-email");
        const toast = document.getElementById("toast");

        copyBtn?.addEventListener("click", () => {
            const email = copyBtn.getAttribute("data-email") || "";
            navigator.clipboard.writeText(email);

            toast?.classList.add("visible");
            setTimeout(() => {
                toast?.classList.remove("visible");
            }, 2500);
